#!name=腾讯体育去广告
#!desc=拦截开屏广告，移除首页信息流、社区文章、赛事页及活动推广组件

[MITM]
hostname = %APPEND%,app.sports.qq.com,config.ab.qq.com,shequ.sports.qq.com,film.video.qq.com

[Map Local]
^https:\/\/config\.ab\.qq\.com\/tab\/GetTabRemoteConfig.* data-type=text data="" status-code=200 header="Content-Type:application/proto"
^https:\/\/config\.ab\.qq\.com\/tab\/GetTabToggle.* data-type=text data="" status-code=200 header="Content-Type:application/proto"

[Script]
TencentSportsFeed = type=http-response,pattern=^https:\/\/app\.sports\.qq\.com\/(?:feeds\/list|m\/matchAfter\/stats|match\/adBanner)\?,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/TencentSportsAdBlock.js,script-update-interval=21600,timeout=10
TencentSportsArticle = type=http-response,pattern=^https:\/\/shequ\.sports\.qq\.com\/topic\/detail\?,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/TencentSportsAdBlock.js,script-update-interval=21600,timeout=10
TencentSportsMatchWidgets = type=http-response,pattern=^https:\/\/app\.sports\.qq\.com\/trpc\.sports_resource\.cgi\.ResourceCGI\/MatchWidgets(?:\?.*)?$,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/TencentSportsAdBlock.js,script-update-interval=21600,timeout=10
TencentSportsColumnWidget = type=http-response,pattern=^https:\/\/app\.sports\.qq\.com\/vaccess\/trpc\.sports_resource\.cgi\.ResourceCGI\/ColumnWidget(?:\?.*)?$,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/TencentSportsAdBlock.js,script-update-interval=21600,timeout=10
TencentSportsVipPopup = type=http-response,pattern=^https:\/\/film\.video\.qq\.com\/x\/sports-vip-channel\/(?:\?.*)?$,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/TencentSportsAdBlock.js,script-update-interval=21600,timeout=10
