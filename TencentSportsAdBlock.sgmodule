#!name=腾讯体育去广告
#!desc=拦截开屏广告，移除首页信息流强插广告与社区文章底部广告

[MITM]
hostname = %APPEND%,app.sports.qq.com,config.ab.qq.com,shequ.sports.qq.com,film.video.qq.com
[Map Local]
^https:\/\/config\.ab\.qq\.com\/tab\/GetTabRemoteConfig.* data-type=text data="" status-code=200 header="Content-Type:application/proto"
^https:\/\/config\.ab\.qq\.com\/tab\/GetTabToggle.* data-type=text data="" status-code=200 header="Content-Type:application/proto"

[Script]
QQSportsFeedAdBlock = type=http-response,pattern=^https:\/\/app\.sports\.qq\.com\/(?:feeds\/list|m\/matchAfter\/stats|match\/adBanner)(?:\?.*)?$,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/QQSportsFeedAdBlock.js,script-update-interval=21600,timeout=10
QQSportsArticleAdBlock = type=http-response,pattern=^https:\/\/shequ\.sports\.qq\.com\/topic\/detail\?,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/QQSportsArticleAdBlock.js,timeout=10
QQSportsMatchWidgetsAdBlock = type=http-response,pattern=^https:\/\/app\.sports\.qq\.com\/trpc\.sports_resource\.cgi\.ResourceCGI\/MatchWidgets(?:\?.*)?$,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/QQSportsMatchWidgetsAdBlock.js,script-update-interval=21600,timeout=10
QQSportsColumnWidgetBlock = type=http-response,pattern=^https:\/\/app\.sports\.qq\.com\/vaccess\/trpc\.sports_resource\.cgi\.ResourceCGI\/ColumnWidget(?:\?.*)?$,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/QQSportsColumnWidgetBlock.js,script-update-interval=21600,timeout=10
QQSportsVipPopupBlock = type=http-response,pattern=^https:\/\/film\.video\.qq\.com\/x\/sports-vip-channel\/(?:\?.*)?$,requires-body=1,script-path=https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/QQSportsVipPopupBlock.js,script-update-interval=21600,timeout=10
